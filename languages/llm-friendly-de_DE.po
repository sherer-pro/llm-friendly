msgstr "Ab 2 Zeichen tippen…"

#: inc/Admin.php:394
msgid "Searching…"
msgstr "Suche…"

#: inc/Admin.php:395
#: inc/Admin.php:469
msgid "Enter at least 2 characters to search."
msgstr "Gib mindestens 2 Zeichen für die Suche ein."

#: inc/Admin.php:396
msgid "Nothing found for this query."
msgstr "Für diese Anfrage wurde nichts gefunden."

#: inc/Admin.php:397
msgid "Add to exclusions"
msgstr "Zu Ausschlüssen hinzufügen"

#: inc/Admin.php:343
#: inc/Admin.php:398
msgid "Remove from exclusions"
msgstr "Aus Ausschlüssen entfernen"

#: inc/Admin.php:399
#: inc/Admin.php:744
msgid "No items are excluded yet."
msgstr "Noch sind keine Elemente ausgeschlossen."

#: inc/Admin.php:400
msgid "Search failed, please try again."
msgstr "Suche fehlgeschlagen, bitte erneut versuchen."

#: inc/Admin.php:424
msgid "llms.txt was regenerated."
msgstr "llms.txt wurde neu erzeugt."

#: inc/Admin.php:432
msgid "Save changes"
msgstr "Änderungen speichern"

#: inc/Admin.php:436
msgid "Maintenance"
msgstr "Wartung"

#: inc/Admin.php:440
msgid "Regenerate llms.txt now"
msgstr "llms.txt jetzt neu erzeugen"

#: inc/Admin.php:442
msgid "Rebuilds cached llms.txt immediately."
msgstr "Erstellt den zwischengespeicherten llms.txt sofort neu."

#: inc/Admin.php:458
#: inc/Admin.php:524
msgid "Access denied."
msgstr "Zugriff verweigert."

#: inc/Admin.php:475
msgid "Post type is not allowed."
msgstr "Dieser Beitragstyp ist nicht erlaubt."

#. translators: %d: Post ID.
#: inc/Admin.php:267
#, php-format
msgid "Item #%d"
msgstr "Element Nr. %d"

#: inc/Admin.php:554
msgid "Enable .md endpoints for selected post types"
msgstr ".md-Endpunkte für ausgewählte Beitragstypen aktivieren"

#: inc/Admin.php:563
msgid "Add X-Robots-Tag: noindex, nofollow header for .md endpoints"
msgstr "X-Robots-Tag: noindex, nofollow-Header für .md-Endpunkte hinzufügen"

#: inc/Admin.php:577
msgid "Example: \"llm\" → /llm/{post_type}/{path}.md"
msgstr "Beispiel: „llm“ → /llm/{post_type}/{path}.md"

#: inc/Admin.php:602
msgid "These types will appear in llms.txt and will have Markdown exports."
msgstr "Diese Typen erscheinen in llms.txt und erhalten Markdown-Exporte."

#: inc/Admin.php:612
msgid "Serve /llms.txt"
msgstr "/llms.txt bereitstellen"

#: inc/Admin.php:621
msgid "Send X-Robots-Tag: noindex, nofollow for /llms.txt"
msgstr "X-Robots-Tag: noindex, nofollow für /llms.txt senden"

#: inc/Admin.php:634
msgid "Auto (on publish/update)"
msgstr "Automatisch (bei Veröffentlichung/Aktualisierung)"

#: inc/Admin.php:635
msgid "Manual only"
msgstr "Nur manuell"

#: inc/Admin.php:638
msgid "In manual mode, use the button in the Maintenance section to rebuild llms.txt."
msgstr "Im manuellen Modus nutze die Schaltfläche im Bereich „Wartung“, um llms.txtneu zu erstellen."

#: inc/Admin.php:651
msgid "How many latest items to list for each post type."
msgstr "Wie viele der neuesten Einträge pro Beitragstyp aufgelistet werden."

#: inc/Admin.php:660
msgid "Add excerpt (if available) under each item in llms.txt"
msgstr "Auszug (falls verfügbar) unter jedem Eintrag in llms.txt hinzufügen"

#: inc/Admin.php:688
msgid "Optional markdown inserted into llms.txt between the site meta and the content sections. Leave empty to insert nothing."
msgstr "Optionales Markdown, das in llms.txt zwischen den Website-Metadaten und denInhaltsabschnitten eingefügt wird. Leer lassen, um nichts einzufügen."

#: inc/Admin.php:704
msgid "Select at least one post type above to manage exclusions."
msgstr "Wähle oben mindestens einen Beitragstyp aus, um Ausschlüsse zu verwalten."

#: inc/Admin.php:709
msgid "Find items by title in real time, add them to the exclusion list, and remove them with one click. <br> Excluded items are omitted from llms.txt and Markdown exports."
msgstr "Finde Einträge in Echtzeit nach Titel, füge sie zur Ausschlussliste hinzuund entferne sie mit einem Klick. <br> Ausgeschlossene Einträge werden ausllms.txt und den Markdown-Exporten weggelassen."

#: inc/Admin.php:734
msgid "Search by title"
msgstr "Nach Titel suchen"

#: inc/Admin.php:737
msgid "Type at least two characters to search. Results appear in the dropdown instantly."
msgstr "Gib mindestens zwei Zeichen ein. Ergebnisse erscheinen sofort im Dropdown."

#: inc/Admin.php:740
msgid "Currently excluded"
msgstr "Derzeit ausgeschlossen"

#: inc/Admin.php:775
msgid "If empty, uses WordPress setting: Site Title."
msgstr "Leer: WordPress-Einstellung „Website-Titel“ wird verwendet."

#: inc/Admin.php:788
msgid "If empty, uses WordPress setting: Tagline."
msgstr "Leer: WordPress-Einstellung „Untertitel“ wird verwendet."

#: inc/Admin.php:813
msgid "Markdown override (LLM Friendly)"
msgstr "Markdown-Überschreibung (LLM Friendly)"

#: inc/Admin.php:841
msgid "If filled, this text will replace the post content in the Markdown export."
msgstr "Wenn ausgefüllt, ersetzt dieser Text den Beitragsinhalt im Markdown-Export."

#: inc/Admin.php:843
msgid "Leave empty to export the post content. You can paste plain Markdown or Gutenberg block markup (<!-- wp: ... -->)."
msgstr "Leer lassen, um den Beitragsinhalt zu exportieren. Du kannst reines Markdownoder Gutenberg-Block-Markup (<!-- wp: ... -->) einfügen."

