msgid "Post types to include"
msgstr "Типи записів для включення"

#: inc/Admin.php:122
msgid "Excluded items"
msgstr "Виключені елементи"

#: inc/Admin.php:130
msgid "llms.txt"
msgstr "llms.txt"

#: inc/Admin.php:137
msgid "Enable llms.txt"
msgstr "Увімкнути llms.txt"

#: inc/Admin.php:145
msgid "Send \"noindex\" header for llms.txt"
msgstr "Надсилати заголовок «noindex» для llms.txt"

#: inc/Admin.php:153
msgid "Regeneration mode"
msgstr "Режим перегенерації"

#: inc/Admin.php:161
msgid "Items per post type"
msgstr "Елементів на тип запису"

#: inc/Admin.php:169
msgid "Show excerpt"
msgstr "Показувати уривок"

#: inc/Admin.php:177
msgid "Sitemap URL"
msgstr "URL карти сайту"

#: inc/Admin.php:185
msgid "Custom markdown block"
msgstr "Користувацький блок Markdown"

#: inc/Admin.php:193
msgid "Site meta overrides"
msgstr "Перевизначення метаданих сайту"

#: inc/Admin.php:200
msgid "Site title override"
msgstr "Перевизначення назви сайту"

#: inc/Admin.php:208
msgid "Site description override"
msgstr "Перевизначення опису сайту"

#: inc/Admin.php:216
msgid "Author override"
msgstr "Перевизначення автора"

#: inc/Admin.php:393
#: inc/Admin.php:735
msgid "Start typing from 2 characters…"
msgstr "Почни вводити від 2 символів…"

#: inc/Admin.php:394
msgid "Searching…"
msgstr "Пошук…"

#: inc/Admin.php:395
#: inc/Admin.php:469
msgid "Enter at least 2 characters to search."
msgstr "Введи щонайменше 2 символи для пошуку."

#: inc/Admin.php:396
msgid "Nothing found for this query."
msgstr "За цим запитом нічого не знайдено."

#: inc/Admin.php:397
msgid "Add to exclusions"
msgstr "Додати до виключень"

#: inc/Admin.php:343
#: inc/Admin.php:398
msgid "Remove from exclusions"
msgstr "Вилучити з виключень"

#: inc/Admin.php:399
#: inc/Admin.php:744
msgid "No items are excluded yet."
msgstr "Поки нічого не виключено."

#: inc/Admin.php:400
msgid "Search failed, please try again."
msgstr "Пошук не вдався, спробуй ще раз."

#: inc/Admin.php:424
msgid "llms.txt was regenerated."
msgstr "llms.txt було згенеровано заново."

#: inc/Admin.php:432
msgid "Save changes"
msgstr "Зберегти зміни"

#: inc/Admin.php:436
msgid "Maintenance"
msgstr "Обслуговування"

#: inc/Admin.php:440
msgid "Regenerate llms.txt now"
msgstr "Перегенерувати llms.txt зараз"

#: inc/Admin.php:442
msgid "Rebuilds cached llms.txt immediately."
msgstr "Негайно перебудовує кешований llms.txt."

#: inc/Admin.php:458
#: inc/Admin.php:524
msgid "Access denied."
msgstr "Доступ заборонено."

#: inc/Admin.php:475
msgid "Post type is not allowed."
msgstr "Тип запису не дозволено."

#. translators: %d: Post ID.
#: inc/Admin.php:267
#, php-format
msgid "Item #%d"
msgstr "Елемент №%d"

#: inc/Admin.php:554
msgid "Enable .md endpoints for selected post types"
msgstr "Увімкнути .md-ендпоїнти для вибраних типів записів"

#: inc/Admin.php:563
msgid "Add X-Robots-Tag: noindex, nofollow header for .md endpoints"
msgstr "Додавати заголовок X-Robots-Tag: noindex, nofollow для .md-ендпоїнтів"

#: inc/Admin.php:577
msgid "Example: \"llm\" → /llm/{post_type}/{path}.md"
msgstr "Приклад: «llm» → /llm/{post_type}/{path}.md"

#: inc/Admin.php:602
msgid "These types will appear in llms.txt and will have Markdown exports."
msgstr "Ці типи з’являться в llms.txt і матимуть експорт у Markdown."

#: inc/Admin.php:612
msgid "Serve /llms.txt"
msgstr "Віддавати /llms.txt"

#: inc/Admin.php:621
msgid "Send X-Robots-Tag: noindex, nofollow for /llms.txt"
msgstr "Надсилати X-Robots-Tag: noindex, nofollow для /llms.txt"

#: inc/Admin.php:634
msgid "Auto (on publish/update)"
msgstr "Авто (під час публікації/оновлення)"

#: inc/Admin.php:635
msgid "Manual only"
msgstr "Лише вручну"

#: inc/Admin.php:638
msgid "In manual mode, use the button in the Maintenance section to rebuild llms.txt."
msgstr "У ручному режимі скористайся кнопкою в розділі «Обслуговування», щобперебудувати llms.txt."

#: inc/Admin.php:651
msgid "How many latest items to list for each post type."
msgstr "Скільки останніх елементів показувати для кожного типу запису."

#: inc/Admin.php:660
msgid "Add excerpt (if available) under each item in llms.txt"
msgstr "Додавати уривок (якщо є) під кожним елементом у llms.txt"

#: inc/Admin.php:688
msgid "Optional markdown inserted into llms.txt between the site meta and the content sections. Leave empty to insert nothing."
msgstr "Необов’язковий Markdown, що вставляється в llms.txt між метаданими сайту тасекцією контенту. Залиш порожнім, щоб нічого не вставляти."

#: inc/Admin.php:704
msgid "Select at least one post type above to manage exclusions."
msgstr "Вибери принаймні один тип запису вище, щоб керувати виключеннями."

#: inc/Admin.php:709
msgid "Find items by title in real time, add them to the exclusion list, and remove them with one click. <br> Excluded items are omitted from llms.txt and Markdown exports."
msgstr "Шукай елементи за заголовком у реальному часі, додавай їх до спискувиключень і вилучай одним кліком. <br> Виключені елементи не потрапляють доllms.txt та експорту в Markdown."

#: inc/Admin.php:734
msgid "Search by title"
msgstr "Пошук за заголовком"

#: inc/Admin.php:737
msgid "Type at least two characters to search. Results appear in the dropdown instantly."
msgstr "Введи щонайменше два символи для пошуку. Результати одразу з’являться увипадаючому списку."

#: inc/Admin.php:740
msgid "Currently excluded"
msgstr "Наразі виключено"

#: inc/Admin.php:775
msgid "If empty, uses WordPress setting: Site Title."
msgstr "Якщо порожньо, використовується налаштування WordPress: «Назва сайту»."

#: inc/Admin.php:788
msgid "If empty, uses WordPress setting: Tagline."
msgstr "Якщо порожньо, використовується налаштування WordPress: «Короткий опис»."

#: inc/Admin.php:811
msgid "If empty, Markdown metadata uses the post author display name."
msgstr "Якщо порожньо, метадані Markdown використовують відображуване ім’я автора запису."

#: inc/Admin.php:813
msgid "Markdown override (LLM Friendly)"
msgstr "Перевизначення Markdown (LLM Friendly)"

#: inc/Admin.php:841
msgid "If filled, this text will replace the post content in the Markdown export."
msgstr "Якщо заповнено, цей текст замінить вміст запису в Markdown-експорті."

#: inc/Admin.php:843
msgid "Leave empty to export the post content. You can paste plain Markdown or Gutenberg block markup (<!-- wp: ... -->)."
msgstr "Залиш порожнім, щоб експортувати вміст запису. Можна вставити чистийMarkdown або розмітку блоків Gutenberg (<!-- wp: ... -->)."

#: inc/Admin.php:874
msgid "llms.txt description (overrides excerpt)"
msgstr "Опис llms.txt (перевизначає уривок)"

#: inc/Admin.php:876
msgid "Optional one-line summary used in llms.txt and Markdown metadata. Leave empty to use the SEO meta description, excerpt, or a generated summary."
msgstr "Необов’язковий однорядковий опис для llms.txt і метаданих Markdown. Залиш порожнім, щоб використовувати SEO-метаопис, уривок або згенерований опис."

#: inc/Exporter.php:92
#: inc/Llms.php:191
#: inc/Plugin.php:250
msgid "Not Found"
msgstr "Не знайдено"

#: inc/Llms.php:267
msgid "LLM-friendly index of this website."
msgstr "LLM-дружній індекс цього сайту."

#: inc/Llms.php:320
msgid "(no published items found)"
msgstr "(опублікованих елементів не знайдено)"

#: llm-friendly.php:170
msgid "Settings"
msgstr "Налаштування"

#: llm-friendly.php:106
msgid "LLM Friendly cannot be activated because the environment does not meet the minimum requirements."
msgstr "LLM Friendly не можна активувати, оскільки середовище не відповідаємінімальним вимогам."

#. Plugin Name of the plugin
#: llm-friendly.php
msgid "LLM Friendly"
msgstr "LLM Friendly"

#. Plugin URI of the plugin
#: llm-friendly.php
msgid "https://github.com/sherer-pro/llm-friendly"
msgstr "https://github.com/sherer-pro/llm-friendly"

#. Description of the plugin
#: llm-friendly.php
msgid "Adds llms.txt and Markdown endpoints to WordPress for LLM-friendly content access."
msgstr "Додає llms.txt і Markdown-ендпоїнти до WordPress для LLM-дружнього доступудо контенту."

#. Author of the plugin
#: llm-friendly.php
msgid "Pavel Sherer"
msgstr "Pavel Sherer"

#. Author URI of the plugin
#: llm-friendly.php
msgid "https://sherer.pro"
msgstr "https://sherer.pro"

