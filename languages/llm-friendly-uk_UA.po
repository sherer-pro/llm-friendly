msgid "LLM Friendly is disabled due to unmet requirements:"
msgstr "LLM Friendly вимкнено через невиконані вимоги:"

#: inc/Admin.php:682
msgid "Same-site absolute URL or site-relative path. Default: /sitemap.xml"
msgstr "Абсолютний URL того ж сайту або шлях відносно сайту. За замовчуванням: /sitemap.xml"
