msgid "Enable Markdown exports"
msgstr "Включить экспорт в Markdown"

#: inc/Admin.php:98
msgid "Send \"noindex\" header for Markdown exports"
msgstr "Отправлять заголовок «noindex» для экспорта в Markdown"

#: inc/Admin.php:106
msgid "Base path for Markdown exports"
msgstr "Базовый путь для экспорта в Markdown"

#: inc/Admin.php:114
msgid "Post types to include"
msgstr "Типы записей для включения"

#: inc/Admin.php:122
msgid "Excluded items"
msgstr "Исключённые элементы"

#: inc/Admin.php:130
msgid "llms.txt"
msgstr "llms.txt"

#: inc/Admin.php:137
msgid "Enable llms.txt"
msgstr "Включить llms.txt"

#: inc/Admin.php:145
msgid "Send \"noindex\" header for llms.txt"
msgstr "Отправлять заголовок «noindex» для llms.txt"

#: inc/Admin.php:153
msgid "Regeneration mode"
msgstr "Режим регенерации"

#: inc/Admin.php:161
msgid "Items per post type"
msgstr "Элементов на тип записи"

#: inc/Admin.php:169
msgid "Show excerpt"
msgstr "Показывать отрывок"

#: inc/Admin.php:177
msgid "Sitemap URL"
msgstr "URL карты сайта"

#: inc/Admin.php:185
msgid "Custom markdown block"
msgstr "Пользовательский блок Markdown"

#: inc/Admin.php:193
msgid "Site meta overrides"
msgstr "Переопределение метаданных сайта"

#: inc/Admin.php:200
msgid "Site title override"
msgstr "Переопределение названия сайта"

#: inc/Admin.php:208
msgid "Site description override"
msgstr "Переопределение описания сайта"

#: inc/Admin.php:216
msgid "Author override"
msgstr "Переопределение автора"

#: inc/Admin.php:401 inc/Admin.php:745
msgid "Start typing from 2 characters…"
msgstr "Начните вводить от 2 символов…"

#: inc/Admin.php:402
msgid "Searching…"
msgstr "Поиск…"

#: inc/Admin.php:476
msgid "Enter at least 2 characters to search."
msgstr "Введите минимум 2 символа для поиска."

#: inc/Admin.php:403
msgid "Nothing found for this query."
msgstr "По этому запросу ничего не найдено."

#: inc/Admin.php:404
msgid "Add to exclusions"
msgstr "Добавить в исключения"

#: inc/Admin.php:351 inc/Admin.php:405
msgid "Remove from exclusions"
msgstr "Удалить из исключений"

#: inc/Admin.php:406 inc/Admin.php:755
msgid "No items are excluded yet."
msgstr "Пока ничего не исключено."

#: inc/Admin.php:407
msgid "Search failed, please try again."
msgstr "Поиск не удался, попробуйте ещё раз."

#: inc/Admin.php:431
msgid "llms.txt was regenerated."
msgstr "llms.txt был сгенерирован заново."

#: inc/Admin.php:439
msgid "Save changes"
msgstr "Сохранить изменения"

#: inc/Admin.php:443
msgid "Maintenance"
msgstr "Обслуживание"

#: inc/Admin.php:447
msgid "Regenerate llms.txt now"
msgstr "Пересоздать llms.txt сейчас"

#: inc/Admin.php:449
msgid "Rebuilds cached llms.txt immediately."
msgstr "Немедленно пересобирает кэшированный llms.txt."

#: inc/Admin.php:465 inc/Admin.php:531
msgid "Access denied."
msgstr "Доступ запрещён."

#: inc/Admin.php:482
msgid "Post type is not allowed."
msgstr "Тип записи не разрешён."

#. translators: %d: Post ID.
#: inc/Admin.php:275
#, php-format
msgid "Item #%d"
msgstr "Элемент №%d"

#: inc/Admin.php:561
msgid "Enable .md endpoints for selected post types"
msgstr "Включить .md-эндпоинты для выбранных типов записей"

#: inc/Admin.php:570
msgid "Add X-Robots-Tag: noindex, nofollow header for .md endpoints"
msgstr "Добавлять заголовок X-Robots-Tag: noindex, nofollow для .md-эндпоинтов"

#: inc/Admin.php:584
msgid "Example: \"llm\" → /llm/{post_type}/{path}.md"
msgstr "Пример: «llm» → /llm/{post_type}/{path}.md"

#: inc/Admin.php:611
msgid "These types will appear in llms.txt and will have Markdown exports."
msgstr "Эти типы появятся в llms.txt и будут иметь экспорт в Markdown."

#: inc/Admin.php:621
msgid "Serve /llms.txt"
msgstr "Отдавать /llms.txt"

#: inc/Admin.php:630
msgid "Send X-Robots-Tag: noindex, nofollow for /llms.txt"
msgstr "Отправлять X-Robots-Tag: noindex, nofollow для /llms.txt"

#: inc/Admin.php:643
msgid "Auto (on publish/update)"
msgstr "Авто (при публикации/обновлении)"

#: inc/Admin.php:644
msgid "Manual only"
msgstr "Только вручную"

#: inc/Admin.php:647
msgid "In manual mode, use the button in the Maintenance section to rebuild llms.txt."
msgstr "В ручном режиме используйте кнопку в разделе «Обслуживание», чтобы пересобрать llms.txt."

#: inc/Admin.php:660
msgid "How many latest items to list for each post type."
msgstr "Сколько последних элементов выводить для каждого типа записи."

#: inc/Admin.php:669
msgid "Add excerpt (if available) under each item in llms.txt"
msgstr "Добавлять отрывок (если есть) под каждым элементом в llms.txt"

#: inc/Admin.php:697
msgid "Optional markdown inserted into llms.txt between the site meta and the content sections. Leave empty to insert nothing."
msgstr "Необязательный Markdown, вставляемый в llms.txt между метаданными сайта и разделами контента. Оставьте пустым, чтобы ничего не вставлять."

#: inc/Admin.php:713
msgid "Select at least one post type above to manage exclusions."
msgstr "Выберите хотя бы один тип записи выше, чтобы управлять исключениями."

#: inc/Admin.php:718
msgid "Find items by title in real time, add them to the exclusion list, and remove them with one click. <br> Excluded items are omitted from llms.txt and Markdown exports."
msgstr "Ищите элементы по заголовку в реальном времени, добавляйте их в список исключений и удаляйте одним кликом. <br> Исключённые элементы не попадают в llms.txt и экспорт в Markdown."

#: inc/Admin.php:743
msgid "Search by title"
msgstr "Поиск по заголовку"

#: inc/Admin.php:748
msgid "Type at least two characters to search. Results appear in the dropdown instantly."
msgstr "Введите минимум два символа для поиска. Результаты сразу появятся в выпадающем списке."

#: inc/Admin.php:751
msgid "Currently excluded"
msgstr "Сейчас исключено"

#: inc/Admin.php:786
msgid "If empty, uses WordPress setting: Site Title."
msgstr "Если пусто, используется настройка WordPress: «Название сайта»."

#: inc/Admin.php:799
msgid "If empty, uses WordPress setting: Tagline."
msgstr "Если пусто, используется настройка WordPress: «Краткое описание»."

#: inc/Admin.php:812
msgid "If empty, Markdown metadata uses the post author display name."
msgstr "Если пусто, в метаданных Markdown используется отображаемое имя автора записи."

#: inc/Admin.php:837
msgid "Markdown override (LLM Friendly)"
msgstr "Переопределение Markdown (LLM Friendly)"

#: inc/Admin.php:871
msgid "If filled, this text will replace the post content in the Markdown export."
msgstr "Если заполнено, этот текст заменит содержимое записи в Markdown-экспорте."

#: inc/Admin.php:873
msgid "Leave empty to export the post content. You can paste plain Markdown or Gutenberg block markup (<!-- wp: ... -->)."
msgstr "Оставьте пустым, чтобы экспортировать содержимое записи. Можно вставить чистый Markdown или разметку блоков Gutenberg (<!-- wp: ... -->)."

#: inc/Admin.php:875
msgid "llms.txt description (overrides excerpt)"
msgstr "Описание llms.txt (переопределяет отрывок)"

#: inc/Admin.php:877
msgid "Optional one-line summary used in llms.txt and Markdown metadata. Leave empty to use the SEO meta description, excerpt, or a generated summary."
msgstr "Необязательное однострочное описание для llms.txt и метаданных Markdown. Оставьте пустым, чтобы использовать SEO-метаописание, отрывок или сгенерированное описание."

#: inc/Exporter.php:95 inc/Llms.php:267 inc/Plugin.php:279
msgid "Not Found"
msgstr "Не найдено"

#: inc/Llms.php:343
msgid "LLM-friendly index of this website."
msgstr "Индекс этого сайта, удобный для LLM."

#: inc/Llms.php:396
msgid "(no published items found)"
msgstr "(опубликованных элементов не найдено)"

#: llm-friendly.php:170
msgid "Settings"
msgstr "Настройки"

#: llm-friendly.php:106
msgid "LLM Friendly cannot be activated because the environment does not meet the minimum requirements."
msgstr "LLM Friendly нельзя активировать, потому что окружение не соответствует минимальным требованиям."

#. Plugin Name of the plugin
#: llm-friendly.php
msgid "LLM Friendly"
msgstr "LLM Friendly"

#. Plugin URI of the plugin
#: llm-friendly.php
msgid "https://github.com/sherer-pro/llm-friendly"
msgstr "https://github.com/sherer-pro/llm-friendly"

#. Description of the plugin
#: llm-friendly.php
msgid "Adds llms.txt and Markdown endpoints to WordPress for LLM-friendly content access."
msgstr "Добавляет llms.txt и Markdown-эндпоинты в WordPress для удобного доступа к контенту для LLM."

#. Author of the plugin
#: llm-friendly.php
msgid "Pavel Sherer"
msgstr "Pavel Sherer"

#. Author URI of the plugin
#: llm-friendly.php
msgid "https://sherer.pro"
msgstr "https://sherer.pro"

