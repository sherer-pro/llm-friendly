msgstr "Элементов на тип записи"

#: inc/Admin.php:169
msgid "Show excerpt"
msgstr "Показывать отрывок"

#: inc/Admin.php:177
msgid "Sitemap URL"
msgstr "URL карты сайта"

#: inc/Admin.php:185
msgid "Custom markdown block"
msgstr "Пользовательский блок Markdown"

#: inc/Admin.php:193
msgid "Site meta overrides"
msgstr "Переопределение метаданных сайта"

#: inc/Admin.php:200
msgid "Site title override"
msgstr "Переопределение названия сайта"

#: inc/Admin.php:208
msgid "Site description override"
msgstr "Переопределение описания сайта"

#: inc/Admin.php:393
#: inc/Admin.php:735
msgid "Start typing from 2 characters…"
msgstr "Начни вводить от 2 символов…"

#: inc/Admin.php:394
msgid "Searching…"
msgstr "Поиск…"

#: inc/Admin.php:395
#: inc/Admin.php:469
msgid "Enter at least 2 characters to search."
msgstr "Введи минимум 2 символа для поиска."

#: inc/Admin.php:396
msgid "Nothing found for this query."
msgstr "По этому запросу ничего не найдено."

#: inc/Admin.php:397
msgid "Add to exclusions"
msgstr "Добавить в исключения"

#: inc/Admin.php:343
#: inc/Admin.php:398
msgid "Remove from exclusions"
msgstr "Удалить из исключений"

#: inc/Admin.php:399
#: inc/Admin.php:744
msgid "No items are excluded yet."
msgstr "Пока ничего не исключено."

#: inc/Admin.php:400
msgid "Search failed, please try again."
msgstr "Поиск не удался, попробуй ещё раз."

#: inc/Admin.php:424
msgid "llms.txt was regenerated."
msgstr "llms.txt был сгенерирован заново."

#: inc/Admin.php:432
msgid "Save changes"
msgstr "Сохранить изменения"

#: inc/Admin.php:436
msgid "Maintenance"
msgstr "Обслуживание"

#: inc/Admin.php:440
msgid "Regenerate llms.txt now"
msgstr "Пересоздать llms.txt сейчас"

#: inc/Admin.php:442
msgid "Rebuilds cached llms.txt immediately."
msgstr "Немедленно пересобирает кэшированный llms.txt."

#: inc/Admin.php:458
#: inc/Admin.php:524
msgid "Access denied."
msgstr "Доступ запрещён."

#: inc/Admin.php:475
msgid "Post type is not allowed."
msgstr "Тип записи не разрешён."

#. translators: %d: Post ID.
#: inc/Admin.php:267
#, php-format
msgid "Item #%d"
msgstr "Элемент №%d"

#: inc/Admin.php:554
msgid "Enable .md endpoints for selected post types"
msgstr "Включить .md-эндпоинты для выбранных типов записей"

#: inc/Admin.php:563
msgid "Add X-Robots-Tag: noindex, nofollow header for .md endpoints"
msgstr "Добавлять заголовок X-Robots-Tag: noindex, nofollow для .md-эндпоинтов"

#: inc/Admin.php:577
msgid "Example: \"llm\" → /llm/{post_type}/{path}.md"
msgstr "Пример: «llm» → /llm/{post_type}/{path}.md"

#: inc/Admin.php:602
msgid "These types will appear in llms.txt and will have Markdown exports."
msgstr "Эти типы появятся в llms.txt и будут иметь экспорт в Markdown."

#: inc/Admin.php:612
msgid "Serve /llms.txt"
msgstr "Отдавать /llms.txt"

#: inc/Admin.php:621
msgid "Send X-Robots-Tag: noindex, nofollow for /llms.txt"
msgstr "Отправлять X-Robots-Tag: noindex, nofollow для /llms.txt"

#: inc/Admin.php:634
msgid "Auto (on publish/update)"
msgstr "Авто (при публикации/обновлении)"

#: inc/Admin.php:635
msgid "Manual only"
msgstr "Только вручную"

#: inc/Admin.php:638
msgid "In manual mode, use the button in the Maintenance section to rebuild llms.txt."
msgstr "В ручном режиме используй кнопку в разделе «Обслуживание», чтобы пересобрать llms.txt."

#: inc/Admin.php:651
msgid "How many latest items to list for each post type."
msgstr "Сколько последних элементов выводить для каждого типа записи."

#: inc/Admin.php:660
msgid "Add excerpt (if available) under each item in llms.txt"
msgstr "Добавлять отрывок (если есть) под каждым элементом в llms.txt"

#: inc/Admin.php:688
msgid "Optional markdown inserted into llms.txt between the site meta and the content sections. Leave empty to insert nothing."
msgstr "Необязательный Markdown, вставляемый в llms.txt между метаданными сайта и секцией контента. Оставь пустым, чтобы ничего не вставлять."

#: inc/Admin.php:704
msgid "Select at least one post type above to manage exclusions."
msgstr "Выбери хотя бы один тип записи выше, чтобы управлять исключениями."

#: inc/Admin.php:709
msgid "Find items by title in real time, add them to the exclusion list, and remove them with one click. <br> Excluded items are omitted from llms.txt and Markdown exports."
msgstr "Ищи элементы по заголовку в реальном времени, добавляй их в cписок исключений и удаляй одним кликом. <br> Исключённые элементы не попадают в llms.txt и экспорт в Markdown."

#: inc/Admin.php:734
msgid "Search by title"
msgstr "Поиск по заголовку"

#: inc/Admin.php:737
msgid "Type at least two characters to search. Results appear in the dropdown instantly."
msgstr "Введи минимум два символа для поиска. Результаты сразу появятся в выпадающем списке."

#: inc/Admin.php:740
msgid "Currently excluded"
msgstr "Сейчас исключено"

#: inc/Admin.php:775
msgid "If empty, uses WordPress setting: Site Title."
msgstr "Если пусто, используется настройка WordPress: «Название сайта»."

#: inc/Admin.php:788
msgid "If empty, uses WordPress setting: Tagline."
msgstr "Если пусто, используется настройка WordPress: «Краткое описание»."

#: inc/Admin.php:813
msgid "Markdown override (LLM Friendly)"
msgstr "Переопределение Markdown (LLM Friendly)"

#: inc/Admin.php:841
msgid "If filled, this text will replace the post content in the Markdown export."
msgstr "Если заполнено, этот текст заменит содержимое записи в Markdown-экспорте."

#: inc/Admin.php:843
msgid "Leave empty to export the post content. You can paste plain Markdown or Gutenberg block markup (<!-- wp: ... -->)."
msgstr "Оставь пустым, чтобы экспортировать содержимое записи. Можно вставить чистыйMarkdown или разметку блоков Gutenberg (<!-- wp: ... -->)."

